---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import { BUSINESS_NAME, CANONICAL_URL } from '../data/site';

interface Props {
  title: string;
  description: string;
  canonicalPath?: string;
  schemas?: object[];
}

const { title, description, canonicalPath = '', schemas = [] } = Astro.props;
const canonical = `${CANONICAL_URL}${canonicalPath}`;

const localBusinessSchema = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  "@id": `${CANONICAL_URL}/#business`,
  "name": BUSINESS_NAME,
  "url": CANONICAL_URL,
  "telephone": "+447881903188",
  "email": "info@scroofing.co.uk",
  "description": "S.C Roofing Ltd — trusted roofing contractors in Bath & Somerset for over 20 years. Repairs, new roofs, flat roofs, chimneys, leadwork and emergency call-outs. NRTC certified, fully insured.",
  "foundingDate": "2004",
  "logo": `${CANONICAL_URL}/logo.svg`,
  "image": `${CANONICAL_URL}/images/roof-bristol.webp`,
  "address": {
    "@type": "PostalAddress",
    "streetAddress": "9 Frenchfield Road",
    "addressLocality": "Peasedown St John",
    "addressRegion": "Bath and North East Somerset",
    "postalCode": "BA2 8SL",
    "addressCountry": "GB"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "51.3337",
    "longitude": "-2.3895"
  },
  "areaServed": [
    { "@type": "City",  "name": "Bath" },
    { "@type": "City",  "name": "Keynsham" },
    { "@type": "Town",  "name": "Radstock" },
    { "@type": "Town",  "name": "Midsomer Norton" },
    { "@type": "Town",  "name": "Frome" },
    { "@type": "Town",  "name": "Trowbridge" },
    { "@type": "Town",  "name": "Shepton Mallet" },
    { "@type": "City",  "name": "Wells" },
    { "@type": "State", "name": "Somerset" }
  ],
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday","Tuesday","Wednesday","Thursday","Friday"],
      "opens": "08:00",
      "closes": "17:00"
    },
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": "Saturday",
      "opens": "08:00",
      "closes": "13:00"
    }
  ],
  "priceRange": "££",
  "currenciesAccepted": "GBP",
  "paymentAccepted": "Cash, Bank Transfer, Cheque",
  "hasOfferCatalog": {
    "@type": "OfferCatalog",
    "name": "Roofing Services",
    "itemListElement": [
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roof Repairs" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "New Roofs" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Flat Roofs" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Chimney Repairs" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Leadwork" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Guttering & Fascias" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Roof Inspections" } },
      { "@type": "Offer", "itemOffered": { "@type": "Service", "name": "Emergency Repairs" } }
    ]
  },
  "aggregateRating": {
    "@type": "AggregateRating",
    "ratingValue": "5",
    "bestRating": "5",
    "worstRating": "1",
    "ratingCount": "3"
  },
  "sameAs": [
    "https://www.facebook.com/scroofingltd",
    "https://www.instagram.com/scroofingltd"
  ]
};
---

<!doctype html>
<html lang="en-GB">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.ico" />

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Barlow+Condensed:wght@300;700;800&family=Bebas+Neue&family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />

    <title>{title}</title>

    <SchemaOrg schemas={[localBusinessSchema, ...schemas]} />
  </head>
  <body>
    <!-- Grain texture overlay -->
    <div class="grain-overlay" aria-hidden="true"></div>

    <Nav />
    <main>
      <slot />
    </main>
    <Footer />

    <!-- Lenis smooth scroll + cursor -->
    <script>
      import Lenis from 'lenis';
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      // ── Smooth scroll ──
      const lenis = new Lenis({ lerp: 0.08, smoothWheel: true });
      lenis.on('scroll', ScrollTrigger.update);
      gsap.ticker.add((time) => lenis.raf(time * 1000));
      gsap.ticker.lagSmoothing(0);

      // ── Nav scroll state ──
      const nav = document.getElementById('site-nav');
      if (nav) {
        ScrollTrigger.create({
          start: 'top -60',
          onEnter:      () => nav.classList.add('nav-scrolled'),
          onLeaveBack:  () => nav.classList.remove('nav-scrolled'),
        });
      }
    </script>
  </body>
</html>
