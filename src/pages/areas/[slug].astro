---
import Layout from '../../layouts/Layout.astro';
import { PHONE, PHONE_HREF } from '../../data/site';
import { areas } from '../../data/areas';
import { services } from '../../data/services';

export function getStaticPaths() {
  return areas.map(a => ({ params: { slug: a.slug }, props: { area: a } }));
}

const { area } = Astro.props;
const nearby = areas.filter(a => a.slug !== area.slug && !a.parent).slice(0, 5);
const subAreas = areas.filter(a => a.parent === area.slug);
const parentArea = area.parent ? areas.find(a => a.slug === area.parent) : null;
const siblingAreas = area.parent ? areas.filter(a => a.parent === area.parent && a.slug !== area.slug) : [];

import { CANONICAL_URL } from '../../data/site';

const areaSchema = {
  "@context": "https://schema.org",
  "@type": "RoofingContractor",
  "@id": `${CANONICAL_URL}/areas/${area.slug}/#business`,
  "name": "S.C Roofing Ltd",
  "url": `${CANONICAL_URL}/areas/${area.slug}`,
  "telephone": "+447881903188",
  "areaServed": { "@type": "City", "name": area.name },
  "description": area.shortDesc,
  "parentOrganization": { "@id": `${CANONICAL_URL}/#business` }
};

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",  "item": CANONICAL_URL },
    { "@type": "ListItem", "position": 2, "name": "Areas", "item": `${CANONICAL_URL}/areas` },
    { "@type": "ListItem", "position": 3, "name": area.name, "item": `${CANONICAL_URL}/areas/${area.slug}` }
  ]
};
---

<Layout title={area.metaTitle} description={area.metaDescription} canonicalPath={`/areas/${area.slug}`} schemas={[areaSchema, breadcrumbSchema]}>

  <!-- Hero -->
  <section class="relative bg-ink overflow-hidden flex flex-col justify-end" style="min-height: clamp(500px, 65vh, 700px);">
    <div class="absolute inset-0" aria-hidden="true">
      <img src="/images/roof-bristol.webp" alt="" class="w-full h-full object-cover object-center" loading="eager" />
      <div class="absolute inset-0 bg-ink/75"></div>
      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-ink to-transparent"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-10 w-full pt-36 pb-16 lg:pb-24">
      <nav class="flex items-center gap-2 text-stone text-xs tracking-wide mb-10">
        <a href="/" class="hover:text-white transition-colors">Home</a>
        <span class="text-white/20">/</span>
        <a href="/areas" class="hover:text-white transition-colors">Areas</a>
        <span class="text-white/20">/</span>
        <span class="text-white">{area.name}</span>
      </nav>
      <div class="flex items-center gap-3 mb-6">
        <span class="w-8 h-px bg-red block"></span>
        <span class="text-red text-xs font-bold uppercase tracking-[0.2em]">{area.driveTime} from base</span>
      </div>
      <h1 class="font-bebas text-white mb-6 leading-none" style="font-size: clamp(4rem, 10vw, 9rem); letter-spacing: 0.02em;">
        {area.h1}
      </h1>
      <p class="text-stone text-xl max-w-2xl leading-relaxed mb-10">{area.shortDesc}</p>
      <div class="flex flex-wrap gap-4">
        <a href={PHONE_HREF} class="inline-flex items-center gap-2 bg-red hover:bg-red-dark text-white font-bold px-6 py-3.5 transition-colors text-sm tracking-widest uppercase">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.6 10.8z"/></svg>
          {PHONE}
        </a>
        <a href="/contact" class="inline-flex items-center gap-2 border border-white/20 hover:border-white text-white/70 hover:text-white font-bold px-6 py-3.5 transition-colors text-sm tracking-widest uppercase">
          Free Quote
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/></svg>
        </a>
      </div>
    </div>
  </section>

  <!-- Parent area link (shown on sub-area pages e.g. Combe Down → Bath) -->
  {parentArea && (
    <div class="bg-ink border-b border-white/8">
      <div class="max-w-7xl mx-auto px-6 lg:px-10 py-4">
        <a href={`/areas/${parentArea.slug}`} class="inline-flex items-center gap-2 text-stone hover:text-white transition-colors text-sm group">
          <svg class="w-3.5 h-3.5 rotate-180 text-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
          </svg>
          <span>Part of <span class="text-white font-medium group-hover:text-red transition-colors">{parentArea.name}</span></span>
        </a>
      </div>
    </div>
  )}

  <!-- Sibling areas (other neighbourhoods in same parent, e.g. Combe Down → other Bath areas) -->
  {siblingAreas.length > 0 && (
    <div class="bg-ink border-b border-white/8">
      <div class="max-w-7xl mx-auto px-6 lg:px-10 py-5">
        <p class="text-white/25 text-[10px] font-bold uppercase tracking-[0.3em] mb-4 font-sans">Other areas in {parentArea?.name}</p>
        <div class="flex flex-wrap gap-2">
          {siblingAreas.map(a => (
            <a href={`/areas/${a.slug}`}
               class="group flex items-center gap-2 border border-white/10 hover:border-red hover:bg-red/5 px-4 py-2 transition-colors duration-200 text-sm">
              <span class="w-1 h-1 bg-red/40 group-hover:bg-red transition-colors shrink-0"></span>
              <span class="text-stone group-hover:text-white transition-colors">{a.name}</span>
            </a>
          ))}
        </div>
      </div>
    </div>
  )}

  <!-- About this area -->
  <section class="bg-ink py-20 border-b border-white/8">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid lg:grid-cols-12 gap-12 lg:gap-16">
        <div class="lg:col-span-7">
          <p class="text-white/25 text-[10px] font-bold uppercase tracking-[0.3em] mb-6 font-sans">About This Area</p>
          <p class="text-stone-light text-lg leading-relaxed">{area.longDesc}</p>
        </div>
        <div class="lg:col-span-5 flex flex-col gap-4">
          <!-- Trust stats -->
          <div class="border border-white/8 p-6 flex items-center gap-5">
            <div class="w-12 h-12 bg-red/10 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
            <div>
              <p class="text-white font-bold text-lg">{area.driveTime} from our depot</p>
              <p class="text-stone text-sm">Peasedown St John, Bath</p>
            </div>
          </div>
          <div class="border border-white/8 p-6 flex items-center gap-5">
            <div class="w-12 h-12 bg-red/10 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/></svg>
            </div>
            <div>
              <p class="text-white font-bold text-lg">NRTC Certified</p>
              <p class="text-stone text-sm">Fully insured · Free surveys</p>
            </div>
          </div>
          <div class="border border-white/8 p-6 flex items-center gap-5">
            <div class="w-12 h-12 bg-red/10 flex items-center justify-center shrink-0">
              <svg class="w-6 h-6 text-red" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <p class="text-white font-bold text-lg">20+ years serving {area.name}</p>
              <p class="text-stone text-sm">Established 2004</p>
            </div>
          </div>
          <div class="bg-red p-6">
            <p class="text-white font-bebas text-2xl mb-1">Need us today?</p>
            <p class="text-white/80 text-sm mb-4">Emergency call-outs available 24/7 across {area.name}.</p>
            <a href={PHONE_HREF} class="inline-flex items-center gap-2 bg-white text-red font-bold text-sm tracking-widest uppercase px-5 py-2.5 hover:bg-cream transition-colors">
              <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.6 10.8z"/></svg>
              {PHONE}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services in this area -->
  <section class="bg-ink-mid py-20 border-b border-white/8">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="flex items-center gap-3 mb-3">
        <span class="w-6 h-px bg-red block"></span>
        <p class="text-red text-[10px] font-bold uppercase tracking-[0.3em] font-sans">What we do in {area.name}</p>
      </div>
      <h2 class="font-bebas text-white mb-12" style="font-size: clamp(2.5rem, 5vw, 4.5rem); letter-spacing: 0.02em;">
        Roofing services in {area.name}
      </h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/8">
        {services.map((s, i) => (
          <a href={`/areas/${area.slug}/${s.slug}`}
             class="group relative flex flex-col justify-end overflow-hidden bg-ink-mid"
             style="min-height: 300px;">
            <img
              src={s.heroImage}
              alt={s.name}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/60 to-ink/10"></div>
            <div class="absolute inset-0 bg-red/0 group-hover:bg-red/15 transition-colors duration-500"></div>
            <div class="relative p-7">
              <span class="block text-red/60 group-hover:text-red text-[10px] font-bold uppercase tracking-[0.3em] mb-3 transition-colors duration-300">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="font-bebas text-white leading-none mb-3 group-hover:text-red transition-colors duration-300" style="font-size: clamp(1.6rem, 2.5vw, 2.2rem); letter-spacing: 0.03em;">
                {s.name}
              </h3>
              <p class="text-stone/70 text-sm leading-relaxed line-clamp-2">{s.shortDesc.split('.')[0]}.</p>
              <div class="mt-5 flex items-center gap-2 text-red/40 group-hover:text-red transition-colors duration-300">
                <span class="text-[10px] tracking-widest uppercase font-bold font-sans">Learn more</span>
                <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Sub-areas (shown on parent pages e.g. Bath → neighbourhoods) -->
  {subAreas.length > 0 && (
    <section class="bg-ink-mid py-16 border-b border-white/8">
      <div class="max-w-7xl mx-auto px-6 lg:px-10">
        <div class="flex items-center gap-3 mb-3">
          <span class="w-6 h-px bg-red block"></span>
          <p class="text-red text-[10px] font-bold uppercase tracking-[0.3em] font-sans">Areas within {area.name}</p>
        </div>
        <h2 class="font-bebas text-white mb-10" style="font-size: clamp(2rem, 4vw, 3.5rem); letter-spacing: 0.02em;">
          Local areas we cover in {area.name}
        </h2>
        <div class="flex flex-wrap gap-3">
          {subAreas.map(a => (
            <a href={`/areas/${a.slug}`}
               class="group flex items-center gap-2 border border-white/10 hover:border-red hover:bg-red/5 px-5 py-3 transition-colors duration-200">
              <span class="w-1 h-1 bg-red/40 group-hover:bg-red transition-colors shrink-0"></span>
              <span class="text-stone group-hover:text-white transition-colors text-sm font-medium">{a.name}</span>
              <svg class="w-3 h-3 text-stone/30 group-hover:text-red transition-colors ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5l7 7-7 7"/>
              </svg>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Nearby areas -->
  <section class="bg-ink py-16 border-b border-white/8">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <p class="text-white/25 text-[10px] font-bold uppercase tracking-[0.3em] mb-8 font-sans">Also covering nearby</p>
      <div class="flex flex-wrap gap-3">
        {nearby.map(a => (
          <a href={`/areas/${a.slug}`}
             class="group flex items-center gap-2 border border-white/10 hover:border-red px-5 py-2.5 transition-colors duration-200">
            <span class="w-1 h-1 bg-red/40 group-hover:bg-red transition-colors"></span>
            <span class="text-stone group-hover:text-white transition-colors text-sm font-medium">{a.name}</span>
            <span class="text-stone/40 text-xs">{a.driveTime}</span>
          </a>
        ))}
        <a href="/areas"
           class="flex items-center gap-2 border border-white/10 hover:border-red px-5 py-2.5 transition-colors duration-200 text-stone hover:text-white text-sm">
          View all areas →
        </a>
      </div>
    </div>
  </section>

  <!-- Bottom CTA -->
  <section class="bg-red py-16">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 flex flex-col sm:flex-row items-start sm:items-center justify-between gap-8">
      <div>
        <h2 class="font-bebas text-white leading-none mb-2" style="font-size: clamp(2rem, 4vw, 3.5rem);">
          Get a free quote in {area.name}
        </h2>
        <p class="text-white/80 text-base">No obligation. We respond within 24 hours.</p>
      </div>
      <div class="flex flex-wrap gap-4 shrink-0">
        <a href={PHONE_HREF} class="inline-flex items-center gap-2 bg-white text-red font-bold px-7 py-4 text-sm tracking-widest uppercase hover:bg-cream transition-colors">
          <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.6 10.8z"/></svg>
          {PHONE}
        </a>
        <a href="/contact" class="inline-flex items-center gap-2 border-2 border-white/40 hover:border-white text-white font-bold px-7 py-4 text-sm tracking-widest uppercase transition-colors">
          Contact Form
        </a>
      </div>
    </div>
  </section>

</Layout>
