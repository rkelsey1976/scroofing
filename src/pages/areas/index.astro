---
import Layout from '../../layouts/Layout.astro';
import { PHONE, PHONE_HREF } from '../../data/site';
import { areas } from '../../data/areas';
import { CANONICAL_URL } from '../../data/site';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",  "item": CANONICAL_URL },
    { "@type": "ListItem", "position": 2, "name": "Areas", "item": `${CANONICAL_URL}/areas` }
  ]
};
---

<Layout
  title="Areas We Cover | Roofing Bath & Somerset | SC Roofing Ltd"
  description="SC Roofing covers Bath, Keynsham, Radstock, Midsomer Norton, Frome, Trowbridge, Shepton Mallet, Wells and surrounding villages. Free quotes across BA and BS postcodes."
  canonicalPath="/areas"
  schemas={[breadcrumbSchema]}
>

  <section class="relative bg-ink pt-36 pb-20 overflow-hidden">
    <div class="absolute inset-0" aria-hidden="true">
      <img src="/images/roof-bristol.webp" alt="" class="w-full h-full object-cover object-center" loading="eager" />
      <div class="absolute inset-0 bg-ink/75"></div>
      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-ink to-transparent"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-10">
      <div class="flex items-center gap-3 mb-8">
        <span class="w-8 h-px bg-red block"></span>
        <span class="text-stone text-xs font-medium tracking-[0.25em] uppercase">Coverage</span>
      </div>
      <h1 class="font-bebas text-white mb-6 leading-none" style="font-size: clamp(4rem, 10vw, 9rem); letter-spacing: 0.02em;">
        Areas we cover
      </h1>
      <p class="text-stone text-xl max-w-xl leading-relaxed">Based in Peasedown St John — 30-mile radius covering Bath, Somerset and north Wiltshire.</p>
    </div>
  </section>

  <section class="bg-ink border-t border-white/8 pb-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      {areas.filter(a => !a.parent).map((area, i) => (
        <a
          href={`/areas/${area.slug}`}
          class="service-row group flex items-center gap-6 py-7 lg:py-8"
        >
          <span class="service-row-num text-stone/30 font-display text-sm font-bold w-8 flex-shrink-0 transition-colors duration-300">
            {String(i + 1).padStart(2, '0')}
          </span>
          <span class="service-row-name font-display text-white text-2xl lg:text-3xl font-bold flex-1 transition-colors duration-300">
            {area.name}
          </span>
          <span class="service-row-desc text-stone text-sm hidden lg:block max-w-sm leading-relaxed transition-colors duration-300">
            {area.driveTime} from base
          </span>
          <span class="service-row-arrow text-white/20 transition-all duration-300 flex-shrink-0">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5">
              <path d="M7 17L17 7M17 7H7M17 7v10" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </span>
        </a>
      ))}
    </div>
  </section>

  <section class="bg-red py-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-bebas text-white mb-6 leading-none" style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: 0.02em;">
        Not on the list? Call us.
      </h2>
      <p class="text-white/70 mb-8">If you're within 35 miles of Peasedown St John, the answer is probably yes.</p>
      <a href={PHONE_HREF} class="inline-flex items-center gap-2 bg-white text-red font-black px-7 py-4 rounded-sm hover:bg-cream transition-colors text-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.6 10.8z"/>
        </svg>
        {PHONE}
      </a>
    </div>
  </section>

</Layout>
