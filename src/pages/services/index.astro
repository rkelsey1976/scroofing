---
import Layout from '../../layouts/Layout.astro';
import { PHONE, PHONE_HREF } from '../../data/site';
import { services } from '../../data/services';
import { CANONICAL_URL } from '../../data/site';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",     "item": CANONICAL_URL },
    { "@type": "ListItem", "position": 2, "name": "Services", "item": `${CANONICAL_URL}/services` }
  ]
};
---

<Layout
  title="Roofing Services Bath & Somerset | SC Roofing Ltd"
  description="Full range of roofing services across Bath and Somerset — repairs, new roofs, flat roofs, chimneys, leadwork, guttering and emergency call-outs. NRTC certified."
  canonicalPath="/services"
  schemas={[breadcrumbSchema]}
>

  <!-- Hero -->
  <section class="relative bg-ink overflow-hidden flex flex-col justify-end" style="min-height: clamp(500px, 65vh, 700px);">
    <div class="absolute inset-0" aria-hidden="true">
      <img src="/images/roof-bristol.webp" alt="" class="w-full h-full object-cover object-center" loading="eager" />
      <div class="absolute inset-0 bg-ink/75"></div>
      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-ink to-transparent"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-10 w-full pt-36 pb-16 lg:pb-24">
      <div class="flex items-center gap-3 mb-8">
        <span class="w-8 h-px bg-red block"></span>
        <span class="text-stone text-xs font-medium tracking-[0.25em] uppercase">What We Do</span>
      </div>
      <h1 class="font-bebas text-white mb-6 leading-none" style="font-size: clamp(4rem, 10vw, 9rem); letter-spacing: 0.02em;">
        Every roofing<br /><span class="text-red">service you need</span>
      </h1>
      <p class="text-stone text-xl max-w-2xl leading-relaxed">From a single slipped tile to a full commercial re-roof — one call, properly done.</p>
    </div>
  </section>

  <!-- Image card grid -->
  <section class="bg-ink py-16 lg:py-24">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-px bg-white/8">
        {services.map((service, i) => (
          <a
            href={`/services/${service.slug}`}
            class="group relative flex flex-col justify-end overflow-hidden bg-ink-mid"
            style="min-height: 360px;"
          >
            <img
              src={service.heroImage}
              alt={service.name}
              class="absolute inset-0 w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
              loading="lazy"
            />
            <div class="absolute inset-0 bg-gradient-to-t from-ink via-ink/60 to-ink/10"></div>
            <div class="absolute inset-0 bg-red/0 group-hover:bg-red/15 transition-colors duration-500"></div>
            <div class="relative p-7">
              <span class="block text-red/60 group-hover:text-red text-[10px] font-bold uppercase tracking-[0.3em] mb-3 transition-colors duration-300">
                {String(i + 1).padStart(2, '0')}
              </span>
              <h2 class="font-bebas text-white leading-none mb-3 group-hover:text-red transition-colors duration-300" style="font-size: clamp(1.6rem, 2.5vw, 2.2rem); letter-spacing: 0.03em;">
                {service.name}
              </h2>
              <p class="text-stone/70 text-sm leading-relaxed line-clamp-2">{service.shortDesc.split('.')[0]}.</p>
              <div class="mt-5 flex items-center gap-2 text-red/40 group-hover:text-red transition-colors duration-300">
                <span class="text-[10px] tracking-widest uppercase font-bold font-sans">Learn more</span>
                <svg class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
                </svg>
              </div>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-red py-20">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <p class="text-white/60 text-xs font-bold uppercase tracking-[0.3em] mb-4">Not sure what you need?</p>
      <h2 class="font-bebas text-white mb-6 leading-none" style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: 0.02em;">
        Just call us and describe what you're seeing.
      </h2>
      <a href={PHONE_HREF} class="inline-flex items-center gap-2.5 bg-white text-red font-black px-7 py-4 rounded-sm hover:bg-cream transition-colors text-lg">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="currentColor">
          <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.6 10.8z"/>
        </svg>
        {PHONE}
      </a>
    </div>
  </section>

</Layout>
