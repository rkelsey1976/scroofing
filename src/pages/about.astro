---
import Layout from '../layouts/Layout.astro';
import { PHONE, PHONE_HREF, accreditations, trustStats, CANONICAL_URL } from '../data/site';

const breadcrumbSchema = {
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home",  "item": CANONICAL_URL },
    { "@type": "ListItem", "position": 2, "name": "About", "item": `${CANONICAL_URL}/about` }
  ]
};
---

<Layout
  title="About SC Roofing Ltd | Bath & Somerset Roofers"
  description="SC Roofing Ltd — a small, privately owned roofing company based in Peasedown St John, Bath. Over 20 years of experience. NRTC certified. Fully insured."
  canonicalPath="/about"
  schemas={[breadcrumbSchema]}
>

  <section class="relative bg-ink overflow-hidden flex flex-col justify-end" style="min-height: clamp(500px, 65vh, 700px);">
    <div class="absolute inset-0" aria-hidden="true">
      <img src="/images/roof-bristol.webp" alt="" class="w-full h-full object-cover object-center" loading="eager" />
      <div class="absolute inset-0 bg-ink/75"></div>
      <div class="absolute inset-x-0 bottom-0 h-1/2 bg-gradient-to-t from-ink to-transparent"></div>
    </div>
    <div class="relative max-w-7xl mx-auto px-6 lg:px-10 w-full pt-36 pb-16 lg:pb-24">
      <div class="flex items-center gap-3 mb-8">
        <span class="w-8 h-px bg-red block"></span>
        <span class="text-stone text-xs font-medium tracking-[0.25em] uppercase">About Us</span>
      </div>
      <h1 class="font-bebas text-white mb-6 leading-none" style="font-size: clamp(4rem, 10vw, 9rem); letter-spacing: 0.02em;">
        Built on<br /><span class="text-red">reputation.</span>
      </h1>
      <p class="text-stone text-xl max-w-2xl leading-relaxed">Small enough to care. Experienced enough to handle anything. Twenty years of doing it properly.</p>
    </div>
  </section>

  <!-- Big quote -->
  <section class="bg-ink border-t border-white/8 py-20">
    <div class="max-w-4xl mx-auto px-6 lg:px-10">
      <p class="font-display text-white/10 text-8xl leading-none -mb-6 select-none" aria-hidden="true">"</p>
      <blockquote class="font-display text-white italic leading-tight mb-8" style="font-size: clamp(1.75rem, 3.5vw, 3rem);">
        We've been fixing Bath's roofs for over 20 years. We're not the cheapest. We're the ones you call back.
      </blockquote>
      <cite class="text-stone text-sm not-italic tracking-wide">— S.C Roofing Ltd, est. 2004</cite>
    </div>
  </section>

  <!-- Story + photo -->
  <section class="bg-cream py-20">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 grid lg:grid-cols-2 gap-16 items-start">
      <div>
        <h2 class="font-display text-ink text-3xl font-bold mb-6">Who we are</h2>
        <div class="space-y-4 text-ink/65 leading-relaxed mb-10">
          <p>S.C Roofing Ltd is a small, privately owned roofing contractor based in Peasedown St John, Bath. We cover Bath, Somerset and north Wiltshire, working on everything from single-tile repairs to full commercial re-roofing projects.</p>
          <p>We've been in business for over 20 years. In that time we've built our reputation on three things: honest advice, quality workmanship, and a tidy finish. We don't oversell. If a repair will do the job, we'll say so.</p>
          <p>We work with homeowners, private landlords, letting agents, architects, building contractors and insurance companies.</p>
        </div>

        <h2 class="font-display text-ink text-3xl font-bold mb-6">Credentials</h2>
        <ul class="space-y-3 mb-10">
          {[
            'NFRC Member — Competent Person Scheme',
            'Fully insured — Public Liability & Employer\'s',
            'Registered in England & Wales',
            'Insurance work accepted — written reports provided',
            'Free surveys — no hard sell',
          ].map(c => (
            <li class="flex items-center gap-3 border-b border-ink/8 pb-3">
              <span class="w-5 h-5 bg-red rounded-full flex items-center justify-center flex-shrink-0">
                <svg xmlns="http://www.w3.org/2000/svg" class="w-3 h-3 text-white" viewBox="0 0 24 24" fill="currentColor">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
                </svg>
              </span>
              <span class="text-ink/80 text-sm">{c}</span>
            </li>
          ))}
        </ul>

        <!-- NFRC Certificates -->
        <p class="text-xs font-bold uppercase tracking-[0.2em] text-ink/40 mb-4">NFRC Certification</p>
        <div class="grid grid-cols-2 gap-4">
          <div class="border border-ink/10 overflow-hidden">
            <img src="/images/unnamed (10).webp" alt="NFRC Competent Person Scheme certificate — SC Roofing Ltd"
              class="w-full object-cover" loading="lazy" />
          </div>
          <div class="border border-ink/10 overflow-hidden">
            <img src="/images/unnamed (8).webp" alt="NFRC Certificate of Membership — SC Roofing Ltd"
              class="w-full object-cover" loading="lazy" />
          </div>
        </div>
      </div>

      <!-- Photo -->
      <div class="relative">
        <div class="overflow-hidden">
          <img src="/images/shane.webp" alt="Shane — SC Roofing Ltd"
            class="w-full object-cover" loading="lazy" />
        </div>
        <div class="bg-ink p-6 border-t-4 border-red">
          <p class="font-bebas text-white text-2xl leading-none mb-1" style="letter-spacing: 0.03em;">S.C Roofing Ltd</p>
          <p class="text-stone text-sm">Peasedown St John · Est. 2004</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Stats -->
  <section class="bg-ink py-20 border-t border-white/8">
    <div class="max-w-7xl mx-auto px-6 lg:px-10">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-10 lg:divide-x divide-white/10">
        {trustStats.map(s => (
          <div class="lg:px-10 first:pl-0 last:pr-0">
            <p class="font-display text-white font-black leading-none mb-2" style="font-size: clamp(3rem, 7vw, 6rem);">
              {s.value}
            </p>
            <p class="text-stone text-xs font-medium uppercase tracking-[0.15em]">{s.label}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-red py-16">
    <div class="max-w-3xl mx-auto px-6 text-center">
      <h2 class="font-bebas text-white mb-6 leading-none" style="font-size: clamp(2.5rem, 5vw, 4rem); letter-spacing: 0.02em;">Ready to get started?</h2>
      <p class="text-white/70 mb-8">Free surveys, honest advice, no hard sell.</p>
      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2 bg-white text-red font-black px-7 py-4 rounded-sm hover:bg-cream transition-colors text-lg">
          Call {PHONE}
        </a>
        <a href="/contact" class="inline-flex items-center justify-center border-2 border-white/30 hover:border-white text-white font-bold px-7 py-4 rounded-sm transition-colors">
          Send a message
        </a>
      </div>
    </div>
  </section>

</Layout>
