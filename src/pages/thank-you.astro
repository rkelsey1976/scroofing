---
import Layout from '../layouts/Layout.astro';
import { PHONE, PHONE_HREF } from '../data/site';
---

<Layout
  title="Thanks — We'll Be In Touch | SC Roofing Ltd"
  description="Thank you for contacting SC Roofing Ltd. We'll get back to you within 24 hours."
  canonicalPath="/thank-you"
>

  <section class="relative bg-ink min-h-screen flex items-center overflow-hidden">

    <!-- Background image -->
    <div class="absolute inset-0" aria-hidden="true">
      <img src="/images/roof-bristol.webp" alt="" class="w-full h-full object-cover object-center" loading="eager" />
      <div class="absolute inset-0 bg-ink/85"></div>
    </div>

    <div class="relative max-w-3xl mx-auto px-6 lg:px-10 py-32 text-center">

      <!-- Tick -->
      <div class="w-16 h-16 bg-red flex items-center justify-center mx-auto mb-10">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8 text-white" viewBox="0 0 24 24" fill="currentColor">
          <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41z"/>
        </svg>
      </div>

      <div class="flex items-center justify-center gap-3 mb-8">
        <span class="w-8 h-px bg-red block"></span>
        <span class="text-stone text-xs font-medium tracking-[0.25em] uppercase">Message Sent</span>
        <span class="w-8 h-px bg-red block"></span>
      </div>

      <h1 class="font-bebas text-white leading-none mb-6" style="font-size: clamp(4rem, 10vw, 9rem); letter-spacing: 0.02em;">
        We'll be<br /><span class="text-red">in touch.</span>
      </h1>

      <p class="text-stone text-xl leading-relaxed mb-12 max-w-lg mx-auto">
        Your message is with us. We aim to respond within 24 hours — usually the same day. If it's urgent, call us directly.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 justify-center">
        <a href={PHONE_HREF} class="inline-flex items-center justify-center gap-2.5 bg-red hover:bg-red-dark text-white font-bold px-8 py-4 transition-colors text-sm tracking-widest uppercase">
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="currentColor">
            <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.6 10.8z"/>
          </svg>
          {PHONE}
        </a>
        <a href="/" class="inline-flex items-center justify-center gap-2 border border-white/20 hover:border-white text-white/70 hover:text-white font-bold px-8 py-4 transition-colors text-sm tracking-widest uppercase">
          Back to home
          <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </a>
      </div>

    </div>
  </section>

</Layout>
