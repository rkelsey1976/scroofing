---
import { PHONE, PHONE_HREF, EMAIL, ADDRESS, BUSINESS_NAME, OPENING_HOURS, socialLinks } from '../data/site';
import { services } from '../data/services';
import { areas } from '../data/areas';
---

<footer class="bg-ink text-white relative overflow-hidden">

  <!-- Grain overlay -->
  <div class="grain-overlay" aria-hidden="true"></div>

  <!-- Subtle red glow -->
  <div class="absolute bottom-0 left-1/2 -translate-x-1/2 w-[80vw] h-[40vh] bg-red/5 blur-[160px] pointer-events-none" aria-hidden="true"></div>

  <!-- ── Top CTA band ── -->
  <div class="relative border-b border-white/8">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-16 lg:py-20">
      <div class="flex flex-col lg:flex-row items-start lg:items-end justify-between gap-10">
        <div class="max-w-xl">
          <p class="text-red text-xs tracking-[0.3em] uppercase font-sans mb-4">Free quotes · No obligation</p>
          <h2 class="font-bebas text-[clamp(3rem,8vw,6rem)] leading-none tracking-wide text-white mb-0">
            Ready to talk<br/><span class="text-red">about your roof?</span>
          </h2>
        </div>
        <div class="flex flex-col sm:flex-row gap-4 lg:pb-2">
          <a href={PHONE_HREF}
             class="group inline-flex items-center gap-3 bg-red hover:bg-red-dark text-white font-bold px-8 py-4 transition-all duration-300 text-sm tracking-widest uppercase">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24">
              <path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.6 10.8z"/>
            </svg>
            {PHONE}
          </a>
          <a href="/contact"
             class="inline-flex items-center gap-3 border border-white/20 hover:border-white text-white font-bold px-8 py-4 transition-all duration-300 text-sm tracking-widest uppercase">
            Get a Quote
            <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3"/>
            </svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Photo strip -->
    <div class="flex gap-px overflow-hidden" style="height: 200px;">
      <div class="flex-1 overflow-hidden relative group">
        <img src="/images/unnamed (4).webp" alt="Roofing work in progress"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
        <div class="absolute inset-0 bg-ink/30 group-hover:bg-ink/10 transition-colors duration-500"></div>
      </div>
      <div class="flex-1 overflow-hidden relative group">
        <img src="/images/unnamed (7).webp" alt="Completed tile roof"
          class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105" loading="lazy" />
        <div class="absolute inset-0 bg-ink/30 group-hover:bg-ink/10 transition-colors duration-500"></div>
      </div>
      <div class="flex-1 overflow-hidden relative group">
        <img src="/images/unnamed (3).webp" alt="Completed roofing job, Somerset"
          class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105" loading="lazy" />
        <div class="absolute inset-0 bg-ink/30 group-hover:bg-ink/10 transition-colors duration-500"></div>
      </div>
      <div class="flex-1 overflow-hidden relative group hidden sm:block">
        <img src="/images/unnamed (6).webp" alt="Dormer roof conversion"
          class="w-full h-full object-cover object-top transition-transform duration-700 group-hover:scale-105" loading="lazy" />
        <div class="absolute inset-0 bg-ink/30 group-hover:bg-ink/10 transition-colors duration-500"></div>
      </div>
    </div>
  </div>

  <!-- ── Main footer grid — desktop ── -->
  <div class="relative hidden lg:block">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-20">
      <div class="grid grid-cols-12 gap-10 xl:gap-14">

        <!-- Brand column -->
        <div class="col-span-4">
          <a href="/" class="inline-block mb-8">
            <img src="/logo.svg" alt="S.C Roofing Ltd" class="h-10 w-auto" />
          </a>
          <p class="text-stone text-sm leading-relaxed mb-8 max-w-xs">
            Over 20 years of specialist roofing across Bath, Somerset and north Wiltshire. NRTC certified. Fully insured. Every job guaranteed.
          </p>

          <!-- Social links -->
          <div class="flex gap-3 mb-10">
            {socialLinks.map(s => (
              <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}
                 class="w-10 h-10 border border-white/15 hover:border-red hover:bg-red/10 flex items-center justify-center transition-all duration-300 group">
                {s.icon === 'facebook' && (
                  <svg class="w-4 h-4 text-white/40 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
                  </svg>
                )}
                {s.icon === 'instagram' && (
                  <svg class="w-4 h-4 text-white/40 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                  </svg>
                )}
              </a>
            ))}
          </div>

          <!-- Accreditation badge -->
          <div class="inline-flex items-center gap-3 border border-white/10 px-4 py-3">
            <div class="w-8 h-8 bg-red/20 flex items-center justify-center">
              <svg class="w-4 h-4 text-red" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4M7.835 4.697a3.42 3.42 0 001.946-.806 3.42 3.42 0 014.438 0 3.42 3.42 0 001.946.806 3.42 3.42 0 013.138 3.138 3.42 3.42 0 00.806 1.946 3.42 3.42 0 010 4.438 3.42 3.42 0 00-.806 1.946 3.42 3.42 0 01-3.138 3.138 3.42 3.42 0 00-1.946.806 3.42 3.42 0 01-4.438 0 3.42 3.42 0 00-1.946-.806 3.42 3.42 0 01-3.138-3.138 3.42 3.42 0 00-.806-1.946 3.42 3.42 0 010-4.438 3.42 3.42 0 00.806-1.946 3.42 3.42 0 013.138-3.138z"/>
              </svg>
            </div>
            <div>
              <p class="text-white text-xs font-bold tracking-wide">NRTC Certified</p>
              <p class="text-stone text-[10px] tracking-wider uppercase">Fully Insured</p>
            </div>
          </div>
        </div>

        <!-- Services column -->
        <div class="col-span-2">
          <p class="text-white/25 text-[10px] font-bold uppercase tracking-[0.3em] mb-6 font-sans">Services</p>
          <ul class="space-y-3">
            {services.map(s => (
              <li>
                <a href={`/services/${s.slug}`}
                   class="group flex items-center gap-2 text-stone hover:text-white transition-colors duration-200 text-sm">
                  <span class="w-1 h-1 bg-red/50 group-hover:bg-red transition-colors shrink-0"></span>
                  {s.name}
                </a>
              </li>
            ))}
          </ul>
        </div>

        <!-- Areas column -->
        <div class="col-span-2">
          <p class="text-white/25 text-[10px] font-bold uppercase tracking-[0.3em] mb-6 font-sans">Areas</p>
          <ul class="space-y-3">
            {areas.filter(a => !a.parent).slice(0, 8).map(a => (
              <li>
                <a href={`/areas/${a.slug}`}
                   class="group flex items-center gap-2 text-stone hover:text-white transition-colors duration-200 text-sm">
                  <span class="w-1 h-1 bg-red/50 group-hover:bg-red transition-colors shrink-0"></span>
                  {a.name}
                </a>
              </li>
            ))}
            <li>
              <a href="/areas" class="text-red hover:text-white transition-colors text-xs tracking-widest uppercase font-bold mt-2 inline-block">
                All areas →
              </a>
            </li>
          </ul>
        </div>

        <!-- Contact + Hours column -->
        <div class="col-span-4">
          <p class="text-white/25 text-[10px] font-bold uppercase tracking-[0.3em] mb-6 font-sans">Depot & Contact</p>

          <address class="not-italic space-y-3 mb-8">
            <div class="flex items-start gap-3">
              <svg class="w-4 h-4 text-red shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/>
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/>
              </svg>
              <p class="text-stone text-sm leading-relaxed">{ADDRESS}</p>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-red shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.502 5.502l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
              </svg>
              <a href={PHONE_HREF} class="text-white font-bold hover:text-red transition-colors">{PHONE}</a>
            </div>
            <div class="flex items-center gap-3">
              <svg class="w-4 h-4 text-red shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
              </svg>
              <a href={`mailto:${EMAIL}`} class="text-stone text-sm hover:text-white transition-colors">{EMAIL}</a>
            </div>
          </address>

          <!-- Opening hours -->
          <p class="text-white/25 text-[10px] font-bold uppercase tracking-[0.3em] mb-4 font-sans">Opening Hours</p>
          <ul class="space-y-2">
            {(() => {
              const weekday = OPENING_HOURS.find(h => h.day === 'Monday');
              const saturday = OPENING_HOURS.find(h => h.day === 'Saturday');
              const sunday = OPENING_HOURS.find(h => h.day === 'Sunday');
              return (
                <>
                  <li class="flex justify-between text-sm border-b border-white/5 pb-2">
                    <span class="text-stone">Mon – Fri</span>
                    <span class="text-white font-medium">{weekday?.opens}–{weekday?.closes}</span>
                  </li>
                  <li class="flex justify-between text-sm border-b border-white/5 pb-2">
                    <span class="text-stone">Saturday</span>
                    <span class={saturday?.opens ? 'text-white font-medium' : 'text-white/25'}>{saturday?.opens ? `${saturday.opens}–${saturday.closes}` : 'Closed'}</span>
                  </li>
                  <li class="flex justify-between text-sm">
                    <span class="text-stone">Sunday</span>
                    <span class="text-white/25">Closed</span>
                  </li>
                </>
              );
            })()}
          </ul>
        </div>

      </div>
    </div>
  </div>

  <!-- ── Mobile accordion layout ── -->
  <div class="relative lg:hidden">
    <div class="max-w-7xl mx-auto px-6">

      <!-- Brand block -->
      <div class="py-10 border-b border-white/8">
        <a href="/" class="inline-block mb-6">
          <img src="/logo.svg" alt="S.C Roofing Ltd" class="h-9 w-auto" />
        </a>
        <p class="text-stone text-sm leading-relaxed mb-6 max-w-sm">
          Over 20 years of specialist roofing across Bath, Somerset and north Wiltshire. NRTC certified. Fully insured.
        </p>
        <!-- Social -->
        <div class="flex gap-3 mb-6">
          {socialLinks.map(s => (
            <a href={s.href} target="_blank" rel="noopener noreferrer" aria-label={s.label}
               class="w-10 h-10 border border-white/15 hover:border-red flex items-center justify-center transition-all duration-300 group">
              {s.icon === 'facebook' && (
                <svg class="w-4 h-4 text-white/40 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M22 12c0-5.523-4.477-10-10-10S2 6.477 2 12c0 4.991 3.657 9.128 8.438 9.878v-6.987H7.898V12h2.54V9.797c0-2.506 1.492-3.89 3.777-3.89 1.094 0 2.238.195 2.238.195v2.46h-1.26c-1.243 0-1.63.771-1.63 1.562V12h2.773l-.443 2.89h-2.33v6.988C18.343 21.128 22 16.991 22 12z"/>
                </svg>
              )}
              {s.icon === 'instagram' && (
                <svg class="w-4 h-4 text-white/40 group-hover:text-white transition-colors" fill="currentColor" viewBox="0 0 24 24">
                  <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838c-3.403 0-6.162 2.759-6.162 6.162s2.759 6.163 6.162 6.163 6.162-2.759 6.162-6.163c0-3.403-2.759-6.162-6.162-6.162zm0 10.162c-2.209 0-4-1.79-4-4 0-2.209 1.791-4 4-4s4 1.791 4 4c0 2.21-1.791 4-4 4zm6.406-11.845c-.796 0-1.441.645-1.441 1.44s.645 1.44 1.441 1.44c.795 0 1.439-.645 1.439-1.44s-.644-1.44-1.439-1.44z"/>
                </svg>
              )}
            </a>
          ))}
        </div>
        <!-- CTA buttons -->
        <div class="flex gap-3">
          <a href={PHONE_HREF} class="flex-1 flex items-center justify-center gap-2 bg-red text-white font-bold text-sm tracking-widest uppercase py-3.5 transition-colors hover:bg-red-dark">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><path d="M6.6 10.8c1.4 2.8 3.8 5.1 6.6 6.6l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02L6.6 10.8z"/></svg>
            Call
          </a>
          <a href="/contact" class="flex-1 flex items-center justify-center border border-white/20 text-white font-bold text-sm tracking-widest uppercase py-3.5 transition-colors hover:border-white">
            Quote
          </a>
        </div>
      </div>

      <!-- Accordion: Services -->
      <div class="border-b border-white/8">
        <button class="footer-acc w-full flex items-center justify-between py-5" aria-expanded="false">
          <span class="text-white/40 text-[10px] font-bold uppercase tracking-[0.3em] font-sans">Services</span>
          <svg class="footer-acc-icon w-4 h-4 text-white/30 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="footer-acc-panel overflow-hidden" style="max-height:0">
          <ul class="space-y-3 pb-6">
            {services.map(s => (
              <li><a href={`/services/${s.slug}`} class="text-stone hover:text-white transition-colors text-sm">{s.name}</a></li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Accordion: Areas -->
      <div class="border-b border-white/8">
        <button class="footer-acc w-full flex items-center justify-between py-5" aria-expanded="false">
          <span class="text-white/40 text-[10px] font-bold uppercase tracking-[0.3em] font-sans">Areas We Cover</span>
          <svg class="footer-acc-icon w-4 h-4 text-white/30 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="footer-acc-panel overflow-hidden" style="max-height:0">
          <ul class="space-y-3 pb-6">
            {areas.filter(a => !a.parent).slice(0, 8).map(a => (
              <li><a href={`/areas/${a.slug}`} class="text-stone hover:text-white transition-colors text-sm">{a.name}</a></li>
            ))}
            <li><a href="/areas" class="text-red text-sm font-bold">All areas →</a></li>
          </ul>
        </div>
      </div>

      <!-- Accordion: Hours -->
      <div class="border-b border-white/8">
        <button class="footer-acc w-full flex items-center justify-between py-5" aria-expanded="false">
          <span class="text-white/40 text-[10px] font-bold uppercase tracking-[0.3em] font-sans">Opening Hours</span>
          <svg class="footer-acc-icon w-4 h-4 text-white/30 transition-transform duration-300" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/>
          </svg>
        </button>
        <div class="footer-acc-panel overflow-hidden" style="max-height:0">
          <ul class="space-y-2 pb-6">
            {OPENING_HOURS.map(h => (
              <li class="flex justify-between text-sm">
                <span class="text-stone">{h.day}</span>
                <span class={h.opens ? 'text-white' : 'text-white/25'}>{h.opens ? `${h.opens}–${h.closes}` : 'Closed'}</span>
              </li>
            ))}
          </ul>
        </div>
      </div>

      <!-- Contact block -->
      <div class="py-8 space-y-3">
        <div class="flex items-start gap-3">
          <svg class="w-4 h-4 text-red shrink-0 mt-0.5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
          <p class="text-stone text-sm leading-relaxed">{ADDRESS}</p>
        </div>
        <a href={`mailto:${EMAIL}`} class="flex items-center gap-3 text-stone hover:text-white transition-colors text-sm">
          <svg class="w-4 h-4 text-red shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
          {EMAIL}
        </a>
      </div>

    </div>
  </div>

  <!-- ── Bottom bar ── -->
  <div class="relative border-t border-white/8">
    <div class="max-w-7xl mx-auto px-6 lg:px-10 py-5 flex flex-col sm:flex-row justify-between items-center gap-3 text-xs text-white/25">
      <p>&copy; {new Date().getFullYear()} {BUSINESS_NAME}. All rights reserved. Registered in England &amp; Wales.</p>
      <div class="flex items-center gap-5">
        <a href="/privacy-policy" class="hover:text-white transition-colors">Privacy Policy</a>
        <span>Site by <a href="https://seo-kings.co.uk" class="hover:text-white transition-colors">SEO Kings</a></span>
      </div>
    </div>
  </div>

</footer>

<script>
  document.querySelectorAll('.footer-acc').forEach(btn => {
    btn.addEventListener('click', function(this: HTMLButtonElement) {
      const panel = this.nextElementSibling as HTMLElement;
      const icon  = this.querySelector('.footer-acc-icon') as HTMLElement;
      const isOpen = this.getAttribute('aria-expanded') === 'true';

      // Close all
      document.querySelectorAll('.footer-acc').forEach(b => {
        b.setAttribute('aria-expanded', 'false');
        const p = b.nextElementSibling as HTMLElement;
        const i = b.querySelector('.footer-acc-icon') as HTMLElement;
        if (p) p.style.maxHeight = '0';
        if (i) i.style.transform = 'rotate(0deg)';
      });

      if (!isOpen) {
        this.setAttribute('aria-expanded', 'true');
        panel.style.maxHeight = panel.scrollHeight + 'px';
        icon.style.transform = 'rotate(180deg)';
      }
    });
  });
</script>
